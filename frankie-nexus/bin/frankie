#!/usr/bin/env node
const { spawn, execSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const args = process.argv.slice(2);
const command = args[0];
const subArgs = args.slice(1);

const NEXUS_ROOT = path.resolve(__dirname, '..');

function printHelp() {
    console.log(`
FRANKIE Nexus CLI
=================
Usage: frankie <command> [options]

Commands:
  status        Check system integration status
  serve         Start the local web dashboard
  social        Interact with Twitter/X (via bird)
  github        Interact with GitHub (via gh)
  crypto        Crypto operations (placeholder)
  
Examples:
  frankie status
  frankie social read https://x.com/username
  frankie serve
    `);
}

if (!command) {
    printHelp();
    process.exit(0);
}

switch (command) {
    case 'status':
        require(path.join(NEXUS_ROOT, 'scripts', 'status.js'));
        break;

    case 'serve':
        console.log("Starting Web Dashboard on http://localhost:8080...");
        const webDir = path.join(NEXUS_ROOT, 'web');
        spawn('python3', ['-m', 'http.server', '8080'], { 
            cwd: webDir, 
            stdio: 'inherit' 
        });
        break;

    case 'social':
        // Pass through to bird
        const birdCmd = `bird ${subArgs.join(' ')}`;
        console.log(`> ${birdCmd}`);
        try {
            execSync(birdCmd, { stdio: 'inherit' });
        } catch (e) {
            console.error("Command failed or bird not found.");
        }
        break;
        
    case 'github':
        const ghCmd = `gh ${subArgs.join(' ')}`;
        console.log(`> ${ghCmd}`);
        try {
            execSync(ghCmd, { stdio: 'inherit' });
        } catch (e) {}
        break;

    case 'crypto':
        console.log("Crypto Wrapper not yet fully implemented. Use skills/solana-defi-agent directly.");
        break;

    case 'intel':
        const intelAction = subArgs[0] || 'status';
        
        if (intelAction === 'register') {
            const platform = subArgs[1];
            if (platform === 'moltenius') {
                require(path.join(NEXUS_ROOT, 'intelligence/moltenius/register.js')).startRegistration();
            } else if (platform === 'dannypost') {
                require(path.join(NEXUS_ROOT, 'intelligence/dannypost/register.js')).startRegistration();
            } else {
                console.log("Usage: frankie intel register [moltenius|dannypost]");
            }
        } else if (intelAction === 'fetch') {
            // Use Aggregator
            require(path.join(NEXUS_ROOT, 'intelligence/aggregator.js')).aggregate();
        } else if (intelAction === 'status') {
            const storagePath = path.join(NEXUS_ROOT, 'intelligence/storage.json');
            if (fs.existsSync(storagePath)) {
                const data = JSON.parse(fs.readFileSync(storagePath, 'utf8'));
                console.log(`\n[Intelligence Report]`);
                console.log(`Total Insights: ${data.insights.length}`);
                
                // Group by Source
                const sources = {};
                data.insights.forEach(i => {
                    sources[i.source] = (sources[i.source] || 0) + 1;
                });
                console.log("Sources:", sources);

                if (data.insights.length > 0) {
                    console.log("\nRecent Insights:");
                    data.insights.slice(0, 3).forEach(latest => {
                        console.log(`- [${latest.source}] ${latest.sentiment} on ${latest.top_asset} (${latest.raw_text})`);
                    });
                }
            } else {
                console.log("No intelligence data gathered yet. Run 'frankie intel fetch'.");
            }
        } else {
            console.log("Usage: frankie intel [register|fetch|status]");
        }
        break;

    default:
        console.log(`Unknown command: ${command}`);
        printHelp();
        break;
}
