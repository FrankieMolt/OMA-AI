#!/bin/bash
COMMAND=$1
shift

MEMORY_FILE="memory/self-review.md"
STATE_FILE="$HOME/.openclaw/self-review-state.json"
THRESHOLD=3600

ensure_state() {
  if [ ! -f "$STATE_FILE" ]; then
    mkdir -p "$(dirname "$STATE_FILE")"
    echo '{"last_check": 0}' > "$STATE_FILE"
  fi
}

case "$COMMAND" in
  check)
    ensure_state
    LAST_CHECK=$(jq .last_check "$STATE_FILE" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    DIFF=$((NOW - LAST_CHECK))
    if [ $DIFF -gt $THRESHOLD ]; then
      echo "ALERT"
    else
      echo "OK"
    fi
    ;;
  log)
    ensure_state
    TAG=$1
    MISS=$2
    FIX=$3
    DATE=$(date -u +"%Y-%m-%d %H:%M:%S")
    mkdir -p "$(dirname "$MEMORY_FILE")"
    echo "- [$DATE] **$TAG**: $MISS -> Fix: $FIX" >> "$MEMORY_FILE"
    echo "{\"last_check\": $(date +%s)}" > "$STATE_FILE"
    echo "Logged."
    ;;
  read)
    if [ -f "$MEMORY_FILE" ]; then
      tail -n 5 "$MEMORY_FILE"
    else
      echo "No reflections yet."
    fi
    ;;
  stats)
    COUNT=0
    if [ -f "$MEMORY_FILE" ]; then
      COUNT=$(wc -l < "$MEMORY_FILE")
    fi
    echo "Reflections: $COUNT"
    ;;
  *)
    echo "Usage: $0 {check|log|read|stats}"
    exit 1
    ;;
esac
