{
  "name": "playwright-audit",
  "version": "1.0.0",
  "description": "Automated testing and auditing system for web applications using Playwright",
  "main": "scripts/audit-all.js",
  "scripts": {
    "audit:all": "node scripts/audit-all.js",
    "audit:site": "node scripts/audit-site.js",
    "test:performance": "node scripts/performance-test.js",
    "test:accessibility": "node scripts/accessibility-test.js",
    "test:seo": "node scripts/seo-test.js",
    "test:visual": "playwright test tests/visual.spec.js",
    "install:browsers": "playwright install chromium",
    "report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@playwright/test": "^1.41.0",
    "lighthouse": "^11.4.0",
    "chrome-launcher": "^1.1.0",
    "axe-core": "^4.8.0",
    "axe-playwright": "^2.0.1",
    "pa11y": "^8.0.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "playwright": "^1.41.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "playwright",
    "testing",
    "audit",
    "performance",
    "accessibility",
    "seo",
    "visual-regression"
