{
  "workspace": "/home/nosyt/.openclaw/workspace",
  "backupDir": "/home/nosyt/backups",
  "targets": {
    "local": {
      "enabled": true,
      "path": "/home/nosyt/backups"
    },
    "git": {
      "enabled": false,
      "repo": "git@github.com:FrankieMolt/agent-backup.git",
      "branch": "main",
      "autoCommit": true
    },
    "s3": {
      "enabled": false,
      "bucket": "agent-backups",
      "prefix": "frankie/",
      "storageClass": "STANDARD_IA"
    },
    "r2": {
      "enabled": false,
      "accountId": "",
      "bucket": "",
      "prefix": "",
      "accessKeyId": "",
      "secretAccessKey": ""
    }
  },
  "include": [
    "MEMORY.md",
    "SOUL.md",
    "USER.md",
    "AGENTS.md",
    "IDENTITY.md",
    "TOOLS.md",
    "HEARTBEAT.md",
    "WORKFLOWS.md",
    "memory/*.md",
    "scripts/",
    "config/",
    ".learnings/"
  ],
  "exclude": [
    "*.log",
    "node_modules/",
    ".git/",
    "*.tmp",
    ".DS_Store",
    ".next/"
  ],
  "compression": true,
  "retention": {
    "daily": 7,
    "weekly": 4,
    "monthly": 12
  },
  "notifications": {
    "enabled": false,
    "onSuccess": "silent",
    "onFailure": "alert"
  },
  "encryption": {
    "enabled": false,
    "method": "gpg",
    "keyId": ""
  }
}
