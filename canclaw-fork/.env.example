# CanClaw Environment Configuration
# Copy this file to .env and customize

# ============================================
# SOVEREIGNTY SETTINGS
# ============================================

# LLM Provider: ollama (local), cohere (Canadian), or openai (not recommended)
LLM_PROVIDER=ollama

# Ollama Configuration (DEFAULT - Fully Local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Alternative models (uncomment to use):
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_MODEL=aya-expanse
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_MODEL=mistral-nemo

# Block foreign APIs (OpenAI, Anthropic, Google)
# Set to 'false' only if you explicitly want to use foreign services
BLOCK_FOREIGN_APIS=true

# Data residency - ensures data stays in specified region
DATA_RESIDENCY=CA

# ============================================
# LANGUAGE & LOCALIZATION
# ============================================

# Language preference: auto (detect), en (English), fr (French)
LANGUAGE_PREFERENCE=auto

# Default system language for responses
DEFAULT_LANGUAGE=en

# Enable bilingual responses when appropriate
BILINGUAL_MODE=true

# ============================================
# PRIVACY & SECURITY
# ============================================

# Telemetry: We respect your privacy. Default is OFF.
TELEMETRY_ENABLED=false

# Analytics (also OFF by default)
ANALYTICS_ENABLED=false

# Crash reports (also OFF by default)
CRASH_REPORTS_ENABLED=false

# Memory backend: local (markdown files), memory (in-memory only)
MEMORY_BACKEND=local

# Memory storage path (relative to project root)
MEMORY_PATH=./memory

# ============================================
# SECURITY & SANDBOX
# ============================================

# Enable sandboxing for tool execution
SANDBOX_ENABLED=true

# Tool permissions: ask (prompt user), allow (auto-allow), deny (auto-deny)
TOOL_PERMISSIONS=ask

# Restricted tools (comma-separated, require explicit permission)
RESTRICTED_TOOLS=shell,browser,filesystem,network

# ============================================
# CANADIAN FEATURES
# ============================================

# Enable Canadian spellchecking
CANADIAN_SPELLING=true

# Use metric system by default
METRIC_SYSTEM=true

# Environment Canada API (free, no key required)
WEATHER_PROVIDER=environment-canada

# Enable CRA/public service integrations
GOVERNMENT_SERVICES_ENABLED=true

# ============================================
# OPTIONAL: CANADIAN API SERVICES
# ============================================

# Cohere (Canadian company - optional, respects sovereignty)
# Get your key at: https://cohere.com
# COHERE_API_KEY=your_key_here
# COHERE_MODEL=command

# ============================================
# OPTIONAL: FOREIGN APIs (NOT RECOMMENDED)
# ============================================

# WARNING: These send data outside Canada
# Only enable if you understand the privacy implications

# OpenAI (US-based)
# ENABLE_OPENAI=false
# OPENAI_API_KEY=

# Anthropic (US-based)
# ENABLE_ANTHROPIC=false
# ANTHROPIC_API_KEY=

# Google AI (US-based)
# ENABLE_GOOGLE=false
# GOOGLE_API_KEY=

# ============================================
# ADVANCED SETTINGS
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable debug mode
DEBUG_MODE=false

# Max tokens for responses
MAX_TOKENS=4096

# Temperature (0.0 - 2.0, higher = more creative)
TEMPERATURE=0.7

# Context window size
CONTEXT_WINDOW=8192

# ============================================
# SYSTEM
# ============================================

# Node environment
NODE_ENV=development

# Port for web interface (if applicable)
PORT=3000

# Host binding
HOST=localhost

# ============================================
# NOTES
# ============================================

# This configuration prioritizes:
# 1. Your privacy and data sovereignty
# 2. Local inference with open models
# 3. Canadian data residency
# 4. Bilingual support
# 5. PIPEDA compliance

# For questions or concerns about privacy:
# https://canclaw.ca/privacy
# support@canclaw.ca
