# CanClaw .gitignore
# Sovereign Canadian AI Assistant

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
.next/
dist/
build/
*.tsbuildinfo

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local
.env.production
.env.development

# Memory and data (user's private data)
memory/*
!memory/.gitkeep
data/*
!data/.gitkeep
!data/examples/

# Logs
logs/
*.log

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker
.dockerignore
docker-compose.override.yml

# Temporary
tmp/
temp/
*.tmp
*.temp

# Audit files (keep recent, ignore old)
audits/*.txt
audits/*.html
!audits/*.md
!audits/deep-*/

# Backup files
*.bak
*.backup
*~

# Canadian data protection
# NEVER commit:
# - Personal user data
# - API keys (even if Canadian)
# - Session tokens
# - Private keys
*.pem
*.key
secrets/
credentials/

# Ollama (if running locally)
.ollama/

# Testing
__tests__/__snapshots__/
coverage/
*.test.ts.snap

# Misc
.cache/
.parcel-cache/
.vercel
.netlify
