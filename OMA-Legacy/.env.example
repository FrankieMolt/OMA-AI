# OpenMarketAccess Environment Configuration
# Copy this file to .env and fill in your values
# Note: Environment variables are validated on startup with Zod
# Required fields are marked with (REQUIRED)

# ========================================
# DATABASE
# ========================================
# For development (embedded PGlite - data resets on restart):
DATABASE_URL=
# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/openmarketaccess

# ========================================
# SOLANA / X402 PAYMENTS
# ========================================
# Treasury wallet for receiving USDC payments
OMA_TREASURY_WALLET=your-solana-wallet-address-here
# USDC Mint Address (Solana mainnet)
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Helius RPC for Solana (get free API key at https://helius.xyz)
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# ========================================
# SUPABASE AUTHENTICATION
# ========================================
NEXT_PUBLIC_SUPABASE_URL=your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ========================================
# AI PROVIDERS
# ========================================
OPENAI_API_KEY=sk-...(REQUIRED for OpenAI)
OPENROUTER_API_KEY=

# ========================================
# NEXTAUTH
# ========================================
NEXTAUTH_SECRET=...(32+ chars REQUIRED)
NEXTAUTH_URL=http://localhost:3000

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
# Enable debug logging:
DEBUG=false
NODE_ENV=development

# ========================================
# Frontend URL
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# DATABASE (local behavior)
# ========================================
# - DATABASE_URL=memory (or unset): in-memory PGlite (resets on start)
# - DATABASE_URL=./local-db/openmarketaccess.pglite: file PGlite
# - DATABASE_URL=postgresql://...: external postgres

# ========================================
# REDIS (Optional)
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# STRIPE PAYMENTS (Optional)
# ========================================
STRIPE_SECRET_KEY=sk_...(REQUIRED for Stripe)
STRIPE_PUBLISHABLE_KEY=pk_...(REQUIRED for Stripe)
