{
  "name": "open-market-access",
  "version": "2.0.0",
  "description": "OpenMarketAccess (OMA) - The Ultimate Agent Framework",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "gateway"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run test --workspace web",
    "test:watch": "npm run test:watch --workspace web",
    "test:coverage": "npm run test:coverage --workspace web",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@percy/cli": "^1.31.8",
    "@percy/cypress": "^3.1.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^1.5.0",
    "cypress": "^13.10.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^1.0.4",
    "eslint-plugin-unicorn": "^53.0.0",
    "husky": "^9.0.11",
    "jsdoc": "^4.0.3",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
