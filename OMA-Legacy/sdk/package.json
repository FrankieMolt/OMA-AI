{
  "name": "@oma/sdk",
  "version": "1.0.0",
  "description": "OpenMarketAccess SDK - Official TypeScript/JavaScript SDK for interacting with the OMA platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./x402": {
      "types": "./dist/x402/index.d.ts",
      "import": "./dist/x402/index.mjs",
      "require": "./dist/x402/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.mjs",
      "require": "./dist/mcp/index.js"
    },
    "./mcp/orchestrator": {
      "types": "./dist/mcp/orchestrator.d.ts",
      "import": "./dist/mcp/orchestrator.mjs",
      "require": "./dist/mcp/orchestrator.js"
    },
    "./a2a": {
      "types": "./dist/a2a/index.d.ts",
      "import": "./dist/a2a/index.mjs",
      "require": "./dist/a2a/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "oma",
    "openmarketaccess",
    "sdk",
    "web3",
    "solana",
    "x402",
    "mcp",
    "a2a",
    "ai",
    "agents"
  ],
  "author": "OpenMarketAccess",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.91.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0"
  },
  "peerDependencies": {},
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
