{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@shared/*": ["apps/web/src/lib/db/*"],
      "@oma/core": ["packages/core/src/index.ts"],
      "@oma/core/*": ["packages/core/src/*"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/src/**/*",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/*/src/**/*",
    "gateway/src/**/*",
    "sdk/src/**/*"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/build/**",
    "**/coverage/**",
    "local-db/**",
    "apps/web/dev.db",
    "apps/web/e2e/**"
  ]
}
