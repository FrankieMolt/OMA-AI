{
  "name": "@oma/core",
  "version": "1.0.0",
  "description": "OpenMarketAccess Core Framework - The AGI Operating System",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.mjs",
      "require": "./dist/memory/index.js"
    },
    "./meta": {
      "types": "./dist/meta/index.d.ts",
      "import": "./dist/meta/index.mjs",
      "require": "./dist/meta/index.js"
    },
    "./voice": {
      "types": "./dist/voice/index.d.ts",
      "import": "./dist/voice/index.mjs",
      "require": "./dist/voice/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.mjs",
      "require": "./dist/context/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "oma",
    "openmarketaccess",
    "agi",
    "agents",
    "memvid",
    "meta-learning",
    "embodied-ai"
  ],
  "author": "OpenMarketAccess",
  "license": "MIT",
  "dependencies": {
    "@oma/memvid": "workspace:*",
    "@oma/sdk": "workspace:*",
    "zod": "^3.23.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
