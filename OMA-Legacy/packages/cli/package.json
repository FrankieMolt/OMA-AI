{
  "name": "@openmarketaccess/cli",
  "version": "0.1.0",
  "description": "OpenMarketAccess CLI - The Command Center for AI Agents",
  "bin": {
    "oma": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/bin.ts --format cjs --clean --minify",
    "dev": "tsup src/bin.ts --format cjs --watch --onSuccess \"node dist/bin.js\"",
    "lint": "eslint src/**"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "execa": "^5.1.1",
    "inquirer": "^8.2.5",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  }
}
