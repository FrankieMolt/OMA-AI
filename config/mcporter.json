{
  "mcpServers": {
    "github-mcp": {
      "command": "npx",
      "args": ["-y", "github-mcp"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {},
      "keepAlive": true,
      "description": "Context7 Documentation MCP by Upstash"
    }
  }
}
