{
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Payment, Authorization" },
        { "key": "Cache-Control", "value": "public, max-age=30" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.tailwindcss.com https://*.vercel.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.vercel.app; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://* blob:; connect-src 'self' https://*;" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/apis", "destination": "/apis.html" },
    { "source": "/mcps", "destination": "/mcps.html" },
    { "source": "/compute", "destination": "/compute.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/community", "destination": "/community.html" },
    { "source": "/theme", "destination": "/theme.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/agents", "destination": "/agents.html" },
    { "source": "/skills", "destination": "/skills.html" },
    { "source": "/llms", "destination": "/llms.html" },
    { "source": "/publish", "destination": "/publish.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/integrations", "destination": "/integrations.html" },
    { "source": "/keys", "destination": "/keys.html" },
    { "source": "/tasks", "destination": "/tasks.html" },
    { "source": "/status", "destination": "/status.html" }
  ]
}
