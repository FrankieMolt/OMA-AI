# =============================================
# OMA-AI Environment Variables Reference
# Copy this file to .env.local and fill in values
# =============================================

# === Supabase (Required) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# === Frontend URL (for CORS) ===
FRONTEND_URL=https://www.oma-ai.com

# === Wallet & Payments ===
NEXT_PUBLIC_WALLET_ADDRESS=0xYourWalletAddress
OMA_AI_PAYMENT_WALLET=0xYourPaymentWalletAddress

# === x402 Payment Signing ===
# Private key (hex encoded, no 0x prefix) for signing EIP-712 payment payloads
X402_SIGNER_PRIVATE_KEY=your-private-key-hex

# === Base RPC URLs ===
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# === Solana RPC URLs ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# === Admin ===
ADMIN_API_KEY=your-admin-secret-key

# === External APIs ===
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
RESEND_API_KEY=re_xxx
HUGGING_FACE_TOKEN=hf_xxx
SEARXNG_URL=http://localhost:8899
WORLD_APP_ID=your-world-app-id

# === Agent (Optional) ===
AGENT_PRIVATE_KEY=your-agent-private-key

# === Vercel (auto-set) ===
VERCEL_URL=your-app.vercel.app
