# OMA-AI Environment Configuration
# Copy to .env.local and fill in values

# ===========================================
# REQUIRED: Supabase (Free Tier)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# REQUIRED: x402 Payments (Base Network)
# ===========================================
# Your wallet private key (from KEYS.md)
PRIVATE_KEY=0x98275b9383fb61c60c1ba04576bfe3d71e57e7310a6370a4bddd773f77f08daa
# Treasury receives payments
TREASURY_WALLET_BASE=0x40AE4455055feeCac30e1EEEcbFE8dBEd77e4eC6
# OpenX402 Facilitator (free)
OPENX402_API_KEY=

# ===========================================
# REQUIRED: External APIs (Free Tiers)
# ===========================================
# CoinGecko - Crypto prices (free, no key)
COINGECKO_API_KEY=

# WeatherAPI - Weather (free tier available)
WEATHER_API_KEY=your-weatherapi-key

# Exa AI Search - Web search (free tier)
EXA_API_KEY=your-exa-key

# Google AI - Gemini for embeddings
GOOGLE_AI_KEY=AIzaSyAzcXfRk-PSGBJlyucmoxcvmbV1rMkI9R0

# NVIDIA - AI models (from KEYS.md)
NVIDIA_API_KEY=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

# Presearch - Decentralized search
PRESEARCH_API_KEY=your-presearch-key

# ===========================================
# OPTIONAL: Analytics
# ===========================================
NEXT_PUBLIC_GA_ID=

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
