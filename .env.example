# OMA-AI Environment Configuration
# Copy to .env.local and fill in BRAND NEW keys

# ===========================================
# REQUIRED: Create new Supabase project
# https://supabase.com
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-new-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-new-service-role-key

# ===========================================
# REQUIRED: x402 Payments (NEW wallet for OMA-AI)
# ===========================================
# Generate NEW wallet for OMA-AI treasury (DO NOT use personal wallet)
# Use: https://app.coinbase.com/wallet or MetaMask
PRIVATE_KEY=0xYOUR_NEW_WALLET_PRIVATE_KEY
TREASURY_WALLET_BASE=0xYOUR_NEW_WALLET_ADDRESS

# OpenX402 - Sign up at https://openx402.ai (free)
OPENX402_API_KEY=your-openx402-key

# ===========================================
# REQUIRED: API Keys (GET FREE TIERS)
# ===========================================
# CoinGecko - Crypto prices (free, no key needed)
# https://www.coingecko.com/en/api

# WeatherAPI - Weather (free tier: 1M calls/month)
# https://www.weatherapi.com/signup.aspx

# Exa AI - Web search (free tier: 1000 searches/month)
# https://dashboard.exa.ai/

# Google AI - Gemini (get new key from https://aistudio.google.com/app/apikey)
GOOGLE_AI_KEY=YOUR_NEW_GOOGLE_AI_KEY

# NVIDIA - AI models (get new key from https://build.nvidia.com/)
NVIDIA_API_KEY=YOUR_NEW_NVIDIA_KEY

# ===========================================
# OPTIONAL: Analytics
# ===========================================
NEXT_PUBLIC_GA_ID=

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913