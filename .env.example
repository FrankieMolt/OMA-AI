# OMA-AI Environment Variables
# Copy this to .env.local and fill in values

# ==========================================
# SUPABASE
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ==========================================
# STRIPE (Payments)
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ==========================================
# AI PROVIDERS
# ==========================================
VENICE_API_KEY=your_venice_api_key
OPENROUTER_API_KEY=sk-or-your_key

# ==========================================
# X402 PAYMENTS (Web3)
# ==========================================
TREASURY_WALLET_BASE=0xYourTreasuryWallet
TREASURY_WALLET_SOLANA=YourSolanaWallet
OPENX402_API_KEY=your_openx402_key

# ==========================================
# REDIS (Rate Limiting - Production)
# ==========================================
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ==========================================
# MONITORING
# ==========================================
SENTRY_DSN=https://your@sentry.io/dsn
VERCEL_ANALYTICS_ID=your_analytics_id

# ==========================================
# FEATURES
# ==========================================
RATE_LIMIT_ENABLED=true
LOGGING_ENABLED=true
ANALYTICS_ENABLED=true

# ==========================================
# MISC
# ==========================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=https://oma-ai.com
NEXT_PUBLIC_APP_NAME=OMA-AI
NEXT_PUBLIC_TRADING_API_URL=http://localhost:3008
