# OMA-AI Production Environment Variables
# DO NOT COMMIT TO GIT

# OpenRouter API Key
OPENROUTER_API_KEY=

# Frontend URLs
NEXT_PUBLIC_API_URL=https://api.oma-ai.com
NEXT_PUBLIC_SITE_URL=https://oma-ai.com

# WalletConnect
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
# Get from: https://cloud.walletconnect.com

# Blockchain RPCs
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# Backend (if deployed separately)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# x402 Treasury
X402_TREASURY_WALLET=0x590FdA238A52bBA79fD4635e73bDAC1eAe558e784

# Node Configuration
NODE_ENV=production